#!/usr/bin/env sh
# filepath: /Users/devinpadron/repos/AntHill/.husky/commit-msg

# Get the commit message from the file
commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Define the Jira ID pattern (e.g., AH-1234)
jira_pattern="[A-Z]+-[0-9]+"

# Check if the commit message contains a Jira ID
if ! echo "$commit_msg" | grep -Eq "$jira_pattern"; then
  branch_name=$(git branch --show-current)
  # Try to extract Jira ID from branch name
  jira_id=$(echo "$branch_name" | grep -Eo "$jira_pattern" | head -1)
  
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🛑 COMMIT BLOCKED: Missing Jira ID in commit message"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  if [ -n "$jira_id" ]; then
    echo "💡 Include '$jira_id' in your commit message."
  else
    echo "💡 Include a Jira ID (e.g., AH-1234) in your commit message."
  fi
  echo ""
  echo "Format: <Jira ID>: <Commit message>"
  echo ""
  echo "Run your commit command again with a valid message."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  exit 1
fi