#!/usr/bin/env node

// Use the command "node run" to run this script
// This script will delete the node_modules, package-lock.json, ios, android, and .expo directories, then run npm install, npx expo prebuild, and npx expo run with the specified platform (ios or android).

const { spawn } = require("child_process");
const fs = require("fs");
const path = require("path");

// Function to delete a directory or file
const deletePath = (pathToDelete) => {
	if (fs.existsSync(pathToDelete)) {
		if (fs.lstatSync(pathToDelete).isDirectory()) {
			fs.rmSync(pathToDelete, { recursive: true });
		} else {
			fs.unlinkSync(pathToDelete);
		}
		console.log(`Deleted: ${pathToDelete}`);
	} else {
		console.log(`Path does not exist: ${pathToDelete}`);
	}
};

// Function to run a command with real-time output
const runCommand = (command, args) => {
	return new Promise((resolve, reject) => {
		const childProcess = spawn(command, args, {
			stdio: "inherit",
			shell: true,
		});

		childProcess.on("close", (code) => {
			if (code === 0) {
				resolve();
			} else {
				reject(new Error(`Command failed with exit code ${code}`));
			}
		});

		childProcess.on("error", (error) => {
			reject(error);
		});
	});
};

// Main function
const main = async () => {
	try {
		// Get platform from command line arguments
		const platform = process.argv[2];
		if (
			platform !== "ios" &&
			platform !== "android" &&
			platform !== undefined
		) {
			console.error(
				"Invalid platform. Please specify 'ios', 'android', or leave it blank."
			);
			return;
		}

		// Delete node_modules/
		deletePath(path.join(__dirname, "node_modules"));

		// Delete package-lock.json
		deletePath(path.join(__dirname, "package-lock.json"));

		// Delete ios/
		deletePath(path.join(__dirname, "ios"));

		// Delete android/
		deletePath(path.join(__dirname, "android"));

		// Delete .expo/
		deletePath(path.join(__dirname, ".expo"));

		// Run npm install
		console.log("Running: npm install");
		await runCommand("npm", ["install"]);

		// Run npx expo prebuild
		console.log("Running: npx expo prebuild");
		await runCommand("npx", ["expo", "prebuild"]);

		// Run npx expo run with optional platform
		if (platform === "ios" || platform === "android") {
			console.log(`Running: npx expo run:${platform}`);
			await runCommand("npx", ["expo", `run:${platform}`]);
		} else {
			console.log("Running: npx expo run");
			await runCommand("npx", ["expo", "run"]);
		}
	} catch (error) {
		console.error("Script failed:", error);
	}
};

// Execute the main function
main();
